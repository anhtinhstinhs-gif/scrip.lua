    if not ESP.Enabled then return end

    for player, cache in pairs(Objects) do
        local char = player.Character
        local hum = char and char:FindFirstChildOfClass("Humanoid")

        if char and hum and hum.Health > 0 then
            if ESP.TeamCheck and player.Team == LocalPlayer.Team then
                for _,l in pairs(cache.Lines) do l.Visible = false end
                cache.Name.Visible = false cache.Health.Visible = false cache.Dist.Visible = false
            else
                local points, pos = GetBoxPoints(char)
                if points then
                    local screenPoints = {}
                    local onScreen = false

                    for i, p in ipairs(points) do
                        local v, vis = Camera:WorldToViewportPoint(p.Position)
                        screenPoints[i] = Vector2.new(v.X, v.Y)
                        if vis then onScreen = true end
                    end

                    if onScreen then
                        -- Vẽ 12 cạnh
                        for i, con in ipairs(connections) do
                            local line = cache.Lines[i]
                            line.From = screenPoints[con[1]]
                            line.To = screenPoints[con[2]]
                            line.Color = ESP.BoxColor
                            line.Visible = ESP.Box
                        end

                        -- Đổi màu theo máu
                        local healthPercent = hum
