-- ESP BOX 3D PRO cho R6 + R15
local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local LocalPlayer = Players.LocalPlayer
local Camera = workspace.CurrentCamera

local ESP = {
    Enabled = true,
    Box = true,
    Name = true,
    Health = true,
    Distance = true,
    BoxColor = Color3.fromRGB(0, 255, 0),
    TeamCheck = false
}

local Objects = {}

-- Tạo Drawing
local function NewLine()
    local line = Drawing.new("Line")
    line.Visible = false
    line.Thickness = 1.5
    line.Transparency = 1
    return line
end

local function NewText()
    local text = Drawing.new("Text")
    text.Visible = false
    text.Size = 13
    text.Center = true
    text.Outline = true
    text.Font = 2
    return text
end

-- Tạo ESP cho player
local function CreateESP(player)
    if player == LocalPlayer then return end
    local cache = {
        Lines = {}, -- 12 cạnh của box
        Name = NewText(),
        Health = NewText(),
        Dist = NewText()
    }
    for i = 1, 12 do
        cache.Lines[i] = NewLine()
    end
    Objects[player] = cache
end

local function RemoveESP(player)
    if Objects[player] then
        for _, v in pairs(Objects[player].Lines) do v:Remove() end
        Objects[player].Name:Remove()
        Objects[player].Health:Remove()
        Objects[player].Dist:Remove()
        Objects[player] = nil
    end
end

-- Lấy 8 điểm góc của Humanoid
local function GetBoxPoints(char)
    local hrp = char:FindFirstChild("HumanoidRootPart")
    local hum = char:FindFirstChildOfClass("Humanoid")
    if not hrp or not hum then return end

    local size = hum.RigType == Enum.HumanoidRigType.R6 and Vector3.new(2.8, 5, 2) or Vector3.new(3, 5.5, 2.2)
    local cf = hrp.CFrame
    local s = size / 2

    return {
        cf * CFrame.new(-s.X, s.Y, -s.Z), -- 1
        cf * CFrame.new( s.X, s.Y, -s.Z), -- 2
        cf * CFrame.new( s.X, s.Y, s.Z), -- 3
        cf * CFrame.new(-s.X, s.Y, s.Z), -- 4
        cf * CFrame.new(-s.X, -s.Y, -s.Z), -- 5
        cf * CFrame.new( s.X, -s.Y, -s.Z), -- 6
        cf * CFrame.new( s.X, -s.Y, s.Z), -- 7
        cf * CFrame.new(-s.X, -s.Y, s.Z), -- 8
    }, hrp.Position
end

-- Kết nối 12 cạnh
local connections = {
    {1,2},{2,3},{3,4},{4,1}, -- Mặt trên
    {5,6},{6,7},{7,8},{8,5}, -- Mặt dưới
    {1,5},{2,6},{3,7},{4,8} -- Cạnh nối
}

-- Loop chính
