-- CHỈ CÒN 2 TOGGLE: Box + Distance
local Toggles = {{"Box", "Box 3D", 45},{"Distance", "Khoảng cách", 70}}
for i, v in ipairs(Toggles) do
    local btn = Instance.new("TextButton")
    btn.Parent = Content
    btn.Position = UDim2.new(0, 10, 0, v[3])
    btn.Size = UDim2.new(1, -20, 0, 20)
    btn.Text = v[2]..": BẬT"
    btn.Font = Enum.Font.Gotham
    btn.TextSize = 12
    btn.BackgroundColor3 = Color3.fromRGB(0, 170, 0)
    btn.Name = v[1]
    btn.MouseButton1Click:Connect(function()
        Settings[v[1]] = not Settings[v[1]]
        btn.Text = v[2]..": "..(Settings[v[1]] and "BẬT" or "TẮT")
        btn.BackgroundColor3 = Settings[v[1]] and Color3.fromRGB(0, 170, 0) or Color3.fromRGB(170, 0, 0)
    end)
