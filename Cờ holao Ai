-- Chỉ cho phép nhập số trong TextBox
speedBox:GetPropertyChangedSignal("Text"):Connect(function()
	local filtered = speedBox.Text:gsub("[^%d]", "") -- chỉ giữ lại chữ số
	if filtered ~= speedBox.Text then
		speedBox.Text = filtered
	end
end)

-- ===== Hàm áp dụng tốc độ =====
local function applySpeed()
	local character = player.Character
	if not character then return end
	local humanoid = character:FindFirstChildOfClass("Humanoid")
	if not humanoid then return end

	if customSpeed then
		humanoid.WalkSpeed = customSpeed
		humanoid.JumpPower = NORMAL_JUMP
	elseif speedOn then
		humanoid.WalkSpeed = BOOST_SPEED
		humanoid.JumpPower = BOOST_JUMP
	else
		humanoid.WalkSpeed = NORMAL_SPEED
		humanoid.JumpPower = NORMAL_JUMP
	end
end

-- Áp dụng lại mỗi khi hồi sinh
player.CharacterAdded:Connect(function()
	task.wait(0.5)
	applySpeed()
end)

-- ===== Nút bật/tắt tốc độ x2 =====
speedBtn.MouseButton1Click:Connect(function()
	customSpeed = nil -- hủy tốc độ tùy chỉnh khi dùng x2
	speedOn = not speedOn
	if speedOn then
		speedBtn.Text = "TỐC ĐỘ X2: BẬT"
		speedBtn.BackgroundColor3 = Color3.fromRGB(200, 60, 60)
	else
		speedBtn.Text = "TỐC ĐỘ X2: TẮT"
		speedBtn.BackgroundColor3 = Color3.fromRGB(60, 180, 90)
	end
	applySpeed()
end)

-- ===== Nút áp dụng tốc độ tùy chỉnh =====
applyBtn.MouseButton1Click:Connect(function()
	local num = tonumber(speedBox.Text)
	if num and num > 0 then
		customSpeed = num
		speedOn = false
		speedBtn.Text = "TỐC ĐỘ X2: TẮT"
		speedBtn.BackgroundColor3 = Color3.fromRGB(60, 180, 90)
		applySpeed()
		applyBtn.Text = "ĐÃ ÁP DỤNG: " .. num
		task.wait(1)
		applyBtn.Text = "ÁP DỤNG TỐC ĐỘ TÙY CHỈNH"
	else
		applyBtn.Text = "VUI LÒNG NHẬP SỐ HỢP LỆ"
		task.wait(1)
		applyBtn.Text = "ÁP DỤNG TỐC ĐỘ TÙY CHỈNH"
	end
end)

-- ===== Nút thu nhỏ / phóng to =====
toggleSizeBtn.MouseButton1Click:Connect(function()
	minimized = not minimized
	if minimized then
		frame:TweenSize(UDim2.new(0, 220, 0, 28), Enum.EasingStyle.Quad, Enum.EasingDirection.Out, 0.2, true)
		content.Visible = false
	else
		content.Visible = true
		frame:TweenSize(UDim2.new(0, 220, 0, 140), Enum.EasingStyle.Quad, Enum.EasingDirection.Out, 0.2, true)
	end
end)

-- ===== Kéo thả menu =====
local dragging = false
local dragStart = nil
local startPos = nil

titleBar.InputBegan:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
		dragging = true
		dragStart = input.Position
		startPos = frame.Position

		input.Changed:Connect(function()
			if input.UserInputState == Enum.UserInputState.End then
				dragging = false
			end
		end)
	end
end)

UserInputService.InputChanged:Connect(function(input)
	if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
		local delta = input.Position - dragStart
		frame.Position = UDim2.new(
			startPos.X.Scale, startPos.X.Offset + delta.X,
			startPos.Y.Scale, startPos.Y.Offset + delta.Y
		)
	end
end)
