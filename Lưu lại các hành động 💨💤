-- Quản lý trạng thái và Biến chống lag
local isLoggingEvents = false
local isLoggingPlayer = false

local lastEventString = ""
local eventRepeatCount = 1

local lastPlayerAction = ""
local playerRepeatCount = 1
local lastPosition = Vector3.new(0, 0, 0)

-- Hàm tối ưu hiển thị danh sách (gộp dòng trùng lặp)
local function updateLogDisplay()
    -- Giữ thanh cuộn tự động đi xuống khi có dòng mới
    LogContainer.CanvasPosition = Vector2.new(0, LogContainer.CanvasSize.Y.Offset)
end

-- Xử lý chức năng Nút 1 (Theo dõi sự kiện Click/UI/Mua vật phẩm)
Button1.MouseButton1Click:Connect(function()
    isLoggingEvents = not isLoggingEvents
    if isLoggingEvents then
        Button1.Text = "Sự Kiện Game: BẬT"
        Button1.BackgroundColor3 = Color3.fromRGB(0, 150, 0)
    else
        Button1.Text = "Sự Kiện Game: TẮT"
        Button1.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
    end
end)

-- Xử lý chức năng Nút 2 (Theo dõi hành động di chuyển của người chơi)
Button2.MouseButton1Click:Connect(function()
    isLoggingPlayer = not isLoggingPlayer
    if isLoggingPlayer then
        Button2.Text = "Người Chơi: BẬT"
        Button2.BackgroundColor3 = Color3.fromRGB(0, 150, 0)
    else
        Button2.Text = "Người Chơi: TẮT"
        Button2.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
    end
end)

-- Lắng nghe sự kiện tương tác chuột / kích hoạt nút trong trò chơi
game:GetService("UserInputService").InputBegan:Connect(function(input, processed)
    if not isLoggingEvents then return end
    
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        local currentEvent = "game:GetService('VirtualInputManager'):SendMouseButtonEvent(click)"
        
        if currentEvent == lastEventString then
            eventRepeatCount = eventRepeatCount + 1
            -- Cập nhật số lượng thay vì in dòng mới chống tràn bộ nhớ
            local lines = string.split(LogText.Text, "\n")
            if #lines > 1 then
                lines[#lines - 1] = " - " .. currentEvent .. " -- [Lặp lại x" .. tostring(eventRepeatCount) .. "]"
                LogText.Text = table.concat(lines, "\n")
            end
        else
            lastEventString = currentEvent
            eventRepeatCount = 1
            LogText.Text = LogText.Text .. " - " .. currentEvent .. "\n"
        end
        updateLogDisplay()
    end
end)

-- Cập nhật vị trí di chuyển liên tục từ RunService (Giảm lag bằng cách kiểm tra khoảng cách thay đổi)
game:GetService("RunService").Heartbeat:Connect(function()
    if not isLoggingPlayer then return end
    
    local player = game:GetService("Players").LocalPlayer
    if player and player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
        local currentPos = player.Character.HumanoidRootPart.Position
        -- Chỉ ghi nhận hành động nếu người chơi dịch chuyển một khoảng cách đáng kể (> 1.5 studs)
        if (currentPos - lastPosition).Magnitude > 1.5 then
            local actionString = "Di Chuyển Đến Vị Trí: " .. string.format("%.1f, %.1f, %.1f", currentPos.X, currentPos.Y, currentPos.Z)
            
            if lastPlayerAction == "Moving" then
                playerRepeatCount = playerRepeatCount + 1
                local lines = string.split(LogText.Text, "\n")
                if #lines > 1 then
                    lines[#lines - 1] = " - " .. actionString .. " -- [Cập nhật hành trình x" .. tostring(playerRepeatCount) .. "]"
                    LogText.Text = table.concat(lines, "\n")
                end
            else
                lastPlayerAction = "Moving"
                playerRepeatCount = 1
                LogText.Text = LogText.Text .. " - " .. actionString .. "\n"
            end
            lastPosition = currentPos
            updateLogDisplay()
        end
    end
end)

-- Chức năng sao chép toàn bộ nhật ký sự kiện vào Clipboard của máy tính
CopyButton.MouseButton1Click:Connect(function()
    if setclipboard then
