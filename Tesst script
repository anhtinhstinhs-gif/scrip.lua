--[[
    MÃ NGUỒN: GIẢ LẬP NGƯNG ĐỌNG THỜI GIAN (CLIENT-SIDE VISUAL)
    MỤC TIÊU: ĐÓNG BĂNG VỊ TRÍ HIỂN THỊ CỦA NGƯỜI CHƠI KHÁC TRÊN MÁY LOCAL TRONG 5 GIÂY
    TÍNH CHẤT: HỢP LỆ, KHÔNG CAN THIỆP SERVER, CHỈ TẠO HIỆU ỨNG THỊ GIÁC
--]]

-- Khai báo các dịch vụ hệ thống
local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local TweenService = game:GetService("TweenService")
local LocalPlayer = Players.LocalPlayer

-- Cấu hình tham số cơ chế
local FREEZE_DURATION = 5.0 -- Thời gian đóng băng (giây)
local isFrozen = false
local snapshots = {}
local renderConnection = nil

-- Hàm khởi tạo và lưu trạng thái vị trí của các nhân vật khác
local function takeSnapshots()
    table.clear(snapshots)
    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character then
            local root = player.Character:FindFirstChild("HumanoidRootPart")
            local humanoid = player.Character:FindFirstChildOfClass("Humanoid")
            if root and humanoid then
                -- Lưu lại CFrame và trạng thái hoạt động của các khớp nối (Animation)
                snapshots[player] = {
                    CFrame = root.CFrame,
                    Velocity = root.AssemblyLinearVelocity,
                    RotVelocity = root.AssemblyAngularVelocity,
                    AnimSpeed = humanoid.WalkSpeed
                }
            end
        end
    end
end

-- Hàm thực thi đóng băng hiển thị cục bộ
local function startVisualFreeze()
    if isFrozen then return end
    isFrozen = true
    
    -- Ghi nhận dữ liệu vị trí tại giây thứ 0
    takeSnapshots()
    
    -- Tạo hiệu ứng mờ màn hình (ColorCorrection) để tăng hiệu ứng thị giác
    local colorCorrection = Instance.new("ColorCorrectionEffect")
    colorCorrection.Saturation = -0.5
    colorCorrection.TintColor = Color3.fromRGB(150, 180, 200)
    colorCorrection.Parent = game.Workspace.CurrentCamera
    
    -- Ngắt cập nhật vị trí thông thường, ép các nhân vật đứng im tại chỗ cũ
    renderConnection = RunService.RenderStepped:Connect(function()
        for player, data in pairs(snapshots) do
            if player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
                local root = player.Character.HumanoidRootPart
                -- Ép CFrame liên tục để chống lại việc cập nhật từ server trên client của bạn
                root.CFrame = data.CFrame
                root.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
                root.AssemblyAngularVelocity = Vector3.new(0, 0, 0)
                
                -- Đóng băng hoạt ảnh
                local humanoid = player.Character:FindFirstChildOfClass("Humanoid")
                if humanoid then
                    for _, track in ipairs(humanoid:GetPlayingAnimationTracks()) do
                        track:AdjustSpeed(0)
                    end
                end
            end
        end
    end)
    
    -- Thiết lập thời gian tự động giải phóng cơ chế sau 5 giây
    task.delay(FREEZE_DURATION, function()
        if isFrozen then
            isFrozen = false
            if renderConnection then
                renderConnection:Disconnect()
                renderConnection = nil
            end
            
            -- Xóa hiệu ứng màn hình
            colorCorrection:Destroy()
            
            -- Khôi phục tốc độ hoạt ảnh và áp dụng hiệu ứng "nhảy vọt" vị trí do đồng bộ lại với Server
            for player, data in pairs(snapshots) do
                if player.Character then
                    local humanoid = player.Character:FindFirstChildOfClass("Humanoid")
                    if humanoid then
                        for _, track in ipairs(humanoid:GetPlayingAnimationTracks()) do
                            track:AdjustSpeed(1)
                        end
                    end
                end
            end
        end
    end)
end

-- Lắng nghe kích hoạt từ hệ thống (Ví dụ gắn với phím bấm hoặc sự kiện game)
-- Sử dụng: Gọi hàm `startVisualFreeze()` khi người chơi sử dụng kỹ năng.
