-------------------------------------------------------------------------
-- CƠ CHẾ LOGIC ĐIỀU KHIỂN ĐÔNG CỨNG VÀ HỦY LỆNH
-------------------------------------------------------------------------

local FREEZE_DURATION = 5.0
local isActive = false
local snapshots = {}
local renderConnection = nil
local colorCorrection = nil
local countdownThread = nil

-- Hàm chụp trạng thái hệ thống cục bộ
local function takeSnapshots()
    table.clear(snapshots)
    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character then
            local root = player.Character:FindFirstChild("HumanoidRootPart")
            local humanoid = player.Character:FindFirstChildOfClass("Humanoid")
            if root and humanoid then
                snapshots[player] = {
                    CFrame = root.CFrame,
                    PlayingAnims = humanoid:GetPlayingAnimationTracks()
                }
            end
        end
    end
end

-- Hàm tắt hoàn toàn tính năng và khôi phục trạng thái
local function stopVisualFreeze()
    if not isActive then return end
    isActive = false
    
    -- Ngắt kết nối vòng lặp RenderStepped ngay lập tức
    if renderConnection then
        renderConnection:Disconnect()
        renderConnection = nil
    end
    
    -- Xóa luồng đếm ngược nếu đang chạy ngầm
    if countdownThread then
        task.cancel(countdownThread)
        countdownThread = nil
    end
    
    -- Xóa hiệu ứng màu màn hình
    if colorCorrection then
        colorCorrection:Destroy()
        colorCorrection = nil
    end
    
    -- Khôi phục hoạt ảnh cho các người chơi khác
    for player, data in pairs(snapshots) do
        if player.Character then
            local humanoid = player.Character:FindFirstChildOfClass("Humanoid")
            if humanoid then
                for _, track in ipairs(humanoid:GetPlayingAnimationTracks()) do
                    track:AdjustSpeed(1)
                end
            end
        end
    end
    
    -- Cập nhật giao diện về trạng thái ban đầu
    StatusCircle.Visible = false
    ActionButton.Text = "BẬT ĐÔNG CỨNG"
    ActionButton.BackgroundColor3 = Color3.fromRGB(46, 204, 113)
end

-- Hàm bật tính năng đông cứng
local function startVisualFreeze()
    if isActive then return end
    isActive = true
    
    -- Cập nhật giao diện khi đang hoạt động
    ActionButton.Text = "TẮT TÍNH NĂNG"
    ActionButton.BackgroundColor3 = Color3.fromRGB(231, 76, 60) -- Đổi sang màu đỏ
    StatusCircle.Visible = true
    CountdownLabel.Text = tostring(FREEZE_DURATION)
    
    takeSnapshots()
    
    -- Khởi tạo hiệu ứng bộ lọc màu thị giác
    colorCorrection = Instance.new("ColorCorrectionEffect")
    colorCorrection.Saturation = -0.5
    colorCorrection.TintColor = Color3.fromRGB(150, 180, 200)
    colorCorrection.Parent = game.Workspace.CurrentCamera
    
    -- Vòng lặp khóa vị trí và đóng băng animation trên client
    renderConnection = RunService.RenderStepped:Connect(function()
        for player, data in pairs(snapshots) do
            if player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
                local root = player.Character.HumanoidRootPart
                root.CFrame = data.CFrame
                root.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
                root.AssemblyAngularVelocity = Vector3.new(0, 0, 0)
                
                local humanoid = player.Character:FindFirstChildOfClass("Humanoid")
                if humanoid then
                    for _, track in ipairs(humanoid:GetPlayingAnimationTracks()) do
                        track:AdjustSpeed(0)
                    end
                end
            end
        end
    end)
    
    -- Xử lý luồng đếm ngược giảm dần từ 5 về 0 giây
    countdownThread = task.defer(function()
        local timeLeft = FREEZE_DURATION
        while timeLeft > 0 and isActive do
            task.wait(1)
            timeLeft = timeLeft - 1
            CountdownLabel.Text = tostring(math.max(0, timeLeft))
        end
        -- Tự động ngắt khi hết thời gian đếm ngược
        if isActive then
            stopVisualFreeze()
        end
    end)
end

-- Sự kiện nhấn nút xử lý việc Chuyển đổi trạng thái (Toggle)
ActionButton.MouseButton1Click:Connect(function()
    if isActive then
        stopVisualFreeze()
    else
        startVisualFreeze()
    end
end)
