local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer

-- 1. TẠO KHUNG GIAO DIỆN TEST
local TestGui = Instance.new("ScreenGui")
TestGui.Name = "Roblox_Image_Test_Script"
TestGui.ResetOnSpawn = false
TestGui.IgnoreGuiInset = true
TestGui.Parent = LocalPlayer:WaitForChild("PlayerGui")

local TestFrame = Instance.new("Frame")
TestFrame.Name = "TestFrame"
TestFrame.Size = UDim2.new(0, 300, 0, 300)
TestFrame.Position = UDim2.new(0.5, -150, 0.5, -150)
TestFrame.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
TestFrame.Active = true
TestFrame.Draggable = true -- Bạn có thể di chuyển bảng này trên màn hình
TestFrame.Parent = TestGui

local Title = Instance.new("TextLabel")
Title.Size = UDim2.new(1, 0, 0, 40)
Title.Text = "HỘP TEST HIỂN THỊ ẢNH"
Title.TextColor3 = Color3.fromRGB(255, 255, 255)
Title.TextSize = 16
Title.Font = Enum.Font.SourceSansBold
Title.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
Title.Parent = TestFrame

-- 2. KHUNG HIỂN THỊ ẢNH CHÍNH (SỬ DỤNG ID BẠN CUNG CẤP)
local ImageDisplay = Instance.new("ImageLabel")
ImageDisplay.Name = "ImageDisplay"
ImageDisplay.Size = UDim2.new(0, 200, 0, 200)
ImageDisplay.Position = UDim2.new(0.5, -100, 0.5, -80)
ImageDisplay.ScaleType = Enum.ScaleType.Fit
ImageDisplay.BackgroundColor3 = Color3.fromRGB(0, 0, 0) -- Nền đen mặc định của khung
ImageDisplay.Parent = TestFrame

-- Thử định dạng chuẩn mã Asset ID của Roblox bằng ID mới của bạn
ImageDisplay.Image = "rbxassetid://115467504724680"

-- 3. NÚT ĐỂ ĐỔI SANG CÁC KIỂU ĐỊNH DẠNG KHÁC NẾU BỊ ĐEN
local FormatButton = Instance.new("TextButton")
FormatButton.Size = UDim2.new(0, 260, 0, 35)
FormatButton.Position = UDim2.new(0.5, -130, 1, -45)
FormatButton.BackgroundColor3 = Color3.fromRGB(0, 170, 255)
FormatButton.Text = "Đang thử: rbxassetid://"
FormatButton.TextColor3 = Color3.fromRGB(255, 255, 255)
FormatButton.TextSize = 14
FormatButton.Font = Enum.Font.SourceSansBold
FormatButton.Parent = TestFrame

local currentFormat = 1
FormatButton.MouseButton1Click:Connect(function()
    currentFormat = currentFormat + 1
    if currentFormat > 3 then currentFormat = 1 end
    
    if currentFormat == 1 then
        ImageDisplay.Image = "rbxassetid://115467504724680"
        FormatButton.Text = "Đang thử: rbxassetid://"
    elseif currentFormat == 2 then
        ImageDisplay.Image = "http://www.roblox.com/asset/?id=115467504724680"
        FormatButton.Text = "Đang thử: Định dạng HTTP gốc"
    elseif currentFormat == 3 then
        ImageDisplay.Image = "rbxthumb://type=Asset&id=115467504724680&w=420&h=420"
        FormatButton.Text = "Đang thử: Định dạng rbxthumb"
    end
end)
