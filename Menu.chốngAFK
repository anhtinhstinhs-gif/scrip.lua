    removeRadioButton.MouseButton1Click:Connect(function()
        local count = 0
        -- Xóa trong Backpack
        for _, item in pairs(backpack:GetChildren()) do
            if item:IsA("Tool") and (item.Name:lower():find("radio") or item.Name:lower():find("boombox")) then
                item:Destroy()
                count = count + 1
            end
        end
        -- Xóa trong tay đang cầm
        if character then
            local holding = character:FindFirstChildOfClass("Tool")
            if holding and (holding.Name:lower():find("radio") or holding.Name:lower():find("boombox")) then
                holding:Destroy()
                count = count + 1
            end
        end
        -- Thông báo
