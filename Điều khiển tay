-- Script điều khiển tay nhân vật di chuyển theo nút bấm (kéo thả)
-- Mỗi nút điều khiển 1 tay: giữ và kéo để di chuyển tay theo hướng kéo

local Players = game:GetService("Players")
local Player = Players.LocalPlayer
local Character = Player.Character or Player.CharacterAdded:Wait()
local Humanoid = Character:WaitForChild("Humanoid")
local RootPart = Character:WaitForChild("HumanoidRootPart")

-- Tạo GUI
local ScreenGui = Instance.new("ScreenGui")
ScreenGui.Parent = Player:WaitForChild("PlayerGui")

-- Nút Trái (Đỏ) - kéo để di chuyển tay trái
local LeftBtn = Instance.new("ImageButton")
LeftBtn.Size = UDim2.new(0, 100, 0, 100)
LeftBtn.Position = UDim2.new(0, 20, 1, -140)
LeftBtn.BackgroundColor3 = Color3.fromRGB(200, 0, 0)
LeftBtn.Image = "rbxassetid://0"
LeftBtn.Parent = ScreenGui

-- Nút Phải (Xanh) - kéo để di chuyển tay phải
local RightBtn = Instance.new("ImageButton")
RightBtn.Size = UDim2.new(0, 100, 0, 100)
RightBtn.Position = UDim2.new(1, -120, 1, -140)
RightBtn.BackgroundColor3 = Color3.fromRGB(0, 200, 0)
RightBtn.Image = "rbxassetid://0"
RightBtn.Parent = ScreenGui

-- Thêm nhãn
local function addLabel(btn, text)
    local label = Instance.new("TextLabel")
    label.Size = UDim2.new(1, 0, 1, 0)
    label.BackgroundTransparency = 1
    label.Text = text
    label.TextColor3 = Color3.fromRGB(255,255,255)
    label.TextScaled = true
    label.Parent = btn
end
addLabel(LeftBtn, "KÉO TAY TRÁI")
addLabel(RightBtn, "KÉO TAY PHẢI")

-- Tạo cánh tay thật (gắn vào nhân vật) - sử dụng Motor6D để điều khiển
local function getArmMotor(armName)
    for _, child in pairs(Character:GetDescendants()) do
        if child:IsA("Motor6D") and child.Name == armName then
            return child
        end
    end
    return nil
end

-- Lấy khớp tay trái và phải (Motor6D)
local leftMotor = getArmMotor("Left Shoulder") or getArmMotor("Left Arm")
local rightMotor = getArmMotor("Right Shoulder") or getArmMotor("Right Arm")

-- Nếu không có Motor6D, tạo mới (cho Robloxian)
if not leftMotor or not rightMotor then
    -- Tạo tay giả nếu không có Motor (dành cho script test)
    local function createDummyArm(side)
        local arm = Instance.new("Part")
        arm.Size = Vector3.new(0.8, 0.8, 2)
        arm.BrickColor = BrickColor.new(side == "Left" and "Bright red" or "Bright green")
        arm.Material = Enum.Material.SmoothPlastic
        arm.Anchored = false
        arm.CanCollide = false
        arm.Parent = Character
        
        local weld = Instance.new("Weld")
        weld.Part0 = RootPart
        weld.Part1 = arm
        weld.C0 = CFrame.new(side == "Left" and -1.5 or 1.5, 0.5, 0)
        weld.Parent = arm
        return weld, arm
    end
    local leftWeld, leftArm = createDummyArm("Left")
    local rightWeld, rightArm = createDummyArm("Right")
    leftMotor = leftWeld
    rightMotor = rightWeld
end

-- Biến lưu vị trí kéo
local leftDragStart = nil
local rightDragStart = nil
local leftOffset = Vector3.new(0, 0, 0)
local rightOffset = Vector3.new(0, 0, 0)

-- Hàm cập nhật vị trí tay theo offset
local function updateLeftArm(offset)
    if leftMotor:IsA("Motor6D") then
        leftMotor.C0 = CFrame.new(-1.5 + offset.X, 0.5 + offset.Y, offset.Z) * CFrame.Angles(0, 0, 0)
    elseif leftMotor:IsA("Weld") then
        leftMotor.C0 = CFrame.new(-1.5 + offset.X, 0.5 + offset.Y, offset.Z) * CFrame.Angles(0, 0, 0)
    end
end

local function updateRightArm(offset)
    if rightMotor:IsA("Motor6D") then
        rightMotor.C0 = CFrame.new(1.5 + offset.X, 0.5 + offset.Y, offset.Z) * CFrame.Angles(0, 0, 0)
    elseif rightMotor:IsA("Weld") then
        rightMotor.C0 = CFrame.new(1.5 + offset.X, 0.5 + offset.Y, offset.Z) * CFrame.Angles(0, 0, 0)
    end
end

-- Xử lý kéo cho nút trái
LeftBtn.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        leftDragStart = input.Position
        -- Lưu offset hiện tại
        local currentPos = leftMotor.C0.Position
        leftOffset = Vector3.new(currentPos.X + 1.5, currentPos.Y - 0.5, currentPos.Z)
    end
end)

LeftBtn.InputChanged:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
        if leftDragStart then
            local delta = input.Position - leftDragStart
            -- Tỉ lệ chuyển đổi: 1 pixel = 0.01 stud
            local moveX = delta.X * 0.01
            local moveY = -delta.Y * 0.01
            local newOffset = leftOffset + Vector3.new(moveX, moveY, 0)
            -- Giới hạn phạm vi di chuyển
            newOffset = Vector3.new(
                math.clamp(newOffset.X, -2, 2),
                math.clamp(newOffset.Y, -1.5, 1.5),
                math.clamp(newOffset.Z, -1, 1)
            )
            updateLeftArm(newOffset)
        end
    end
end)

LeftBtn.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        leftDragStart = nil
    end
end)

-- Xử lý kéo cho nút phải
RightBtn.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        rightDragStart = input.Position
        local currentPos = rightMotor.C0.Position
        rightOffset = Vector3.new(currentPos.X - 1.5, currentPos.Y - 0.5, currentPos.Z)
    end
end)

RightBtn.InputChanged:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
        if rightDragStart then
            local delta = input.Position - rightDragStart
            local moveX = delta.X * 0.01
            local moveY = -delta.Y * 0.01
            local newOffset = rightOffset + Vector3.new(moveX, moveY, 0)
            newOffset = Vector3.new(
                math.clamp(newOffset.X, -2, 2),
                math.clamp(newOffset.Y, -1.5, 1.5),
                math.clamp(newOffset.Z, -1, 1)
            )
            updateRightArm(newOffset)
        end
    end
end)

RightBtn.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        rightDragStart = nil
    end
end)

-- Reset khi nhân vật respawn
Player.CharacterAdded:Connect(function(newChar)
    Character = newChar
    RootPart = Character:WaitForChild("HumanoidRootPart")
    Humanoid = Character:WaitForChild("Humanoid")
    -- Cập nhật lại Motor
    leftMotor = getArmMotor("Left Shoulder") or getArmMotor("Left Arm")
    rightMotor = getArmMotor("Right Shoulder") or getArmMotor("Right Arm")
    if not leftMotor or not rightMotor then
        -- Tạo lại tay giả
        local lw, la = createDummyArm("Left")
        local rw, ra = createDummyArm("Right")
        leftMotor = lw
        rightMotor = rw
    end
    -- Reset về vị trí mặc định
    updateLeftArm(Vector3.new(0, 0, 0))
    updateRightArm(Vector3.new(0, 0, 0))
end)

print("Script kéo thả tay đã chạy. Kéo nút Đỏ để di chuyển tay trái, kéo nút Xanh để di chuyển tay phải.")
