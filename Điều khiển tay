-- Roblox Head Aimlock Script - V4 (Có kiểm tra vật cản + chỉ aim người chơi khác)
local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local Camera = workspace.CurrentCamera
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")
local ContextActionService = game:GetService("ContextActionService")

-- Trạng thái
local AimBotEnabled = false
local HoldToAim = false
local IsMouseHeld = false
local AimDistance = 200  -- Khoảng cách tối đa để aim (studs)

-- =====================================================================
-- BẮT SỰ KIỆN GIỮ CHUỘT (ContextActionService - KHÔNG BỊ CHẶN)
-- =====================================================================
local function onMouseAction(actionName, inputState, inputObject)
    if actionName == "AimHold" then
        if inputState == Enum.UserInputState.Begin then
            IsMouseHeld = true
        elseif inputState == Enum.UserInputState.End then
            IsMouseHeld = false
        end
    end
end

ContextActionService:BindAction("AimHold", onMouseAction, false, 
    Enum.UserInputType.MouseButton1, 
    Enum.UserInputType.Touch
)

-- =====================================================================
-- HÀM KIỂM TRA VẬT CẢN (CÓ TƯỜNG/BLOCK CHẮN KHÔNG?)
-- =====================================================================
local function isTargetVisible(targetPart)
    -- Kiểm tra nhân vật của mình có tồn tại không
    if not LocalPlayer.Character then
        return false
    end
    
    -- Lấy vị trí mắt camera (điểm bắn tia)
    local origin = Camera.CFrame.Position
    
    -- Lấy vị trí của mục tiêu (đầu)
    local targetPosition = targetPart.Position
    
    -- Hướng từ mắt đến mục tiêu
    local direction = (targetPosition - origin)
    
    -- Khoảng cách từ mắt đến mục tiêu
    local distance = direction.Magnitude
    
    -- Nếu xa hơn khoảng cách tối đa thì không aim
    if distance > AimDistance then
        return false
    end
    
    -- Tạo tham số cho tia kiểm tra
    local raycastParams = RaycastParams.new()
    
    -- Bỏ qua nhân vật của mình và camera (không tự chặn)
    raycastParams.FilterType = Enum.RaycastFilterType.Exclude
    raycastParams.FilterDescendantsInstances = {LocalPlayer.Character, Camera}
    
    -- Bỏ qua nước (không coi nước là vật cản)
    raycastParams.IgnoreWater = true
    
    -- BẮN TIA KIỂM TRA
    local hitResult = workspace:Raycast(origin, direction, raycastParams)
    
    -- Nếu có vật gì đó chặn đường
    if hitResult then
        local hitObject = hitResult.Instance
        
        -- Nếu vật chặn đó là một phần của nhân vật mục tiêu
        -- → Không có vật cản (vì mục tiêu là người chơi)
        if hitObject and hitObject:IsDescendantOf(targetPart.Parent) then
            return true  -- NHÌN THẤY, ĐƯỢC AIM
        end
        
        -- Ngược lại: có tường/block chặn → KHÔNG AIM
        return false
    end
    
    -- Không có gì chặn đường → NHÌN THẤY, ĐƯỢC AIM
    return true
end

-- =====================================================================
-- HÀM TÌM NGƯỜI CHƠI GẦN NHẤT (CHỈ AIM NGƯỜI KHÁC, CÓ KIỂM TRA VẬT CẢN)
-- =====================================================================
local function GetClosestPlayer()
    local ClosestPlayer = nil
    local ShortestDistance = math.huge
    local MousePosition = UserInputService:GetMouseLocation()

    -- Duyệt qua tất cả người chơi trong game
    for _, Player in ipairs(Players:GetPlayers()) do
        -- ❌ BỎ QUA CHÍNH MÌNH - CHỈ AIM NGƯỜI KHÁC
        if Player ~= LocalPlayer then
            local character = Player.Character
            if character then
                local Humanoid = character:FindFirstChildOfClass("Humanoid")
                -- Kiểm tra người chơi còn sống không
                if Humanoid and Humanoid.Health > 0 then
                    -- Lấy phần đầu (HEAD) để aim
                    local Head = character:FindFirstChild("Head")
                    if Head then
                        -- Kiểm tra xem người này có nằm trong màn hình không
                        local ScreenPosition, OnScreen = Camera:WorldToViewportPoint(Head.Position)
                        
                        if OnScreen then
                            -- ✅ KIỂM TRA VẬT CẢN: chỉ aim nếu không có tường/block chắn
                            if isTargetVisible(Head) then
                                -- Tính khoảng cách từ chuột đến người đó trên màn hình
                                local Distance = (Vector2.new(ScreenPosition.X, ScreenPosition.Y) - MousePosition).Magnitude
                                
                                if Distance < ShortestDistance then
                                    ClosestPlayer = Player
                                    ShortestDistance = Distance
                                end
                            end
                        end
                    end
                end
            end
        end
    end
    return ClosestPlayer
end

-- =====================================================================
-- VÒNG LẶP AIMLOCK
-- =====================================================================
RunService.RenderStepped:Connect(function()
    -- Nếu AIM đang TẮT thì thoát
    if not AimBotEnabled then return end

    -- Kiểm tra chế độ giữ chuột
    if HoldToAim and not IsMouseHeld then
        return  -- Không giữ chuột → không aim
    end

    -- Tìm người chơi gần nhất (tự động kiểm tra vật cản bên trong)
    local Target = GetClosestPlayer()
    
    if Target and Target.Character and Target.Character:FindFirstChild("Head") then
        -- AIM VÀO ĐẦU CỦA NGƯỜI CHƠI KHÁC
        Camera.CFrame = CFrame.new(Camera.CFrame.Position, Target.Character.Head.Position)
    end
end)

