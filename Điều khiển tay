-- Nút Thu Nhỏ / Mở Rộng (Nút O)
local ToggleSizeButton = Instance.new("TextButton")
ToggleSizeButton.Size = UDim2.new(0, 30, 0, 30)
ToggleSizeButton.Position = UDim2.new(0.85, 0, 0, 0)
ToggleSizeButton.BackgroundTransparency = 1
ToggleSizeButton.Text = "[ O ]"
ToggleSizeButton.TextColor3 = Color3.fromRGB(255, 255, 255)
ToggleSizeButton.Font = Enum.Font.SourceSansBold
ToggleSizeButton.TextSize = 14
ToggleSizeButton.Parent = MainMenu

local IsMinimized = false
local OriginalSize = MainMenu.Size

ToggleSizeButton.MouseButton1Click:Connect(function()
    if IsMinimized then
        MainMenu.Size = OriginalSize
        for _, child in ipairs(MainMenu:GetChildren()) do
            if child ~= Title and child ~= ToggleSizeButton and child:IsA("GuiObject") then
                child.Visible = true
            end
        end
        ToggleSizeButton.Text = "[ O ]"
    else
        MainMenu.Size = UDim2.new(0, 220, 0, 30)
        for _, child in ipairs(MainMenu:GetChildren()) do
            if child ~= Title and child ~= ToggleSizeButton and child:IsA("GuiObject") then
                child.Visible = false
            end
        end
        ToggleSizeButton.Text = "[ O ]"
    end
    IsMinimized = not IsMinimized
end)

