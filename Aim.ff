<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Crosshair Overlay</title>
    <style>
        /* Đặt giao diện nền trong suốt hoặc tối để dễ quan sát */
        body {
            margin: 0;
            padding: 0;
            background-color: #1a1a1a;
            overflow: hidden;
            width: 100vw;
            height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
        }

        /* Định dạng vòng tròn tâm */
        .crosshair-circle {
            width: 150px; /* Đường kính của vòng tròn */
            height: 150px;
            border: 2px solid #ff66b2; /* Màu sắc và độ dày của viền (hồng giống trong ảnh) */
            border-radius: 50%; /* Bo góc 50% để tạo thành hình tròn */
            position: absolute;
            pointer-events: none; /* Tránh cản trở thao tác chạm trên màn hình */
            box-shadow: 0 0 8px rgba(255, 102, 178, 0.5); /* Hiệu ứng phát sáng nhẹ */
        }

        /* Chấm nhỏ ở chính giữa vòng tròn (tùy chọn) */
        .center-dot {
            width: 4px;
            height: 4px;
            background-color: #00ff00; /* Màu xanh lá cho chấm tâm */
            border-radius: 50%;
            position: absolute;
            pointer-events: none;
        }
    </style>
</head>
<body>

    <!-- Các phần tử giao diện -->
    <div class="crosshair-circle"></div>
    <div class="center-dot"></div>

    <script>
        // Đoạn mã JavaScript này có thể mở rộng nếu cần cấu hình động
        console.log("Crosshair overlay đã được tải cấu trúc thành công.");
    </script>
</body>
</html>
