-- 7. LOGIC ĐIỀU KHIỂN NHÂN VẬT & KHỞI TẠO HỆ THỐNG NỀN
local currentSpeed = 16
local currentJump = 50

local function updateCharacter(char)
    local humanoid = char:WaitForChild("Humanoid")
    if humanoid then
        humanoid.UseJumpPower = true
        humanoid.WalkSpeed = currentSpeed
        humanoid.JumpPower = currentJump
    end
end

LocalPlayer.CharacterAdded:Connect(updateCharacter)
if LocalPlayer.Character then updateCharacter(LocalPlayer.Character) end

-- TÍNH NĂNG: NHẢY LIÊN TỤC (INFINITE JUMP)
UserInputService.JumpRequest:Connect(function()
    if LocalPlayer.Character and LocalPlayer.Character:FindFirstChildOfClass("Humanoid") then
        LocalPlayer.Character:FindFirstChildOfClass("Humanoid"):ChangeState("Jumping")
    end
end)

-- TÍNH NĂNG MỚI 1: TỰ XÂY VÒNG TRÒN TẠI CHỖ KHÔNG GÂY LỖI GAME
local function buildCircleAroundPlayer()
    local character = LocalPlayer.Character
    if not character or not character:FindFirstChild("HumanoidRootPart") then return end
    
    local centerPos = character.HumanoidRootPart.Position - Vector3.new(0, 3, 0) -- Chiều cao nền đất dưới chân
    local radius = 8 -- Bán kính vòng tròn xung quanh bạn
    local segments = 12 -- Số lượng khối gạch tạo thành vòng tròn
    
    for i = 1, segments do
        local angle = (i / segments) * math.pi * 2
        local xOffset = math.cos(angle) * radius
        local zOffset = math.sin(angle) * radius
        
        local part = Instance.new("Part")
        part.Size = Vector3.new(4, 2, 2)
        part.Position = centerPos + Vector3.new(xOffset, 1, zOffset)
        part.CFrame = CFrame.lookAt(part.Position, Vector3.new(centerPos.X, part.Position.Y, centerPos.Z))
        part.Anchored = true
        part.Material = Enum.Material.Brick
        part.BrickColor = BrickColor.new("Bright red")
        part.Parent = workspace
    end
end

-- TÍNH NĂNG MỚI 2: NẰM XUỐNG NGAY TẠI CHỖ (LAY DOWN)
local isLaidDown = false
local function layDownPlayer()
    local character = LocalPlayer.Character
    if not character or not character:FindFirstChild("HumanoidRootPart") then return end
    local hrp = character.HumanoidRootPart
    
    if not isLaidDown then
        -- Xoay nhân vật nằm ngang song song mặt đất
        hrp.CFrame = hrp.CFrame * CFrame.Angles(math.rad(-90), 0, 0)
        isLaidDown = true
    else
        -- Đứng dậy bình thường
        hrp.CFrame = hrp.CFrame * CFrame.Angles(math.rad(95), 0, 0)
        isLaidDown = false
    end
end

