local RainbowObjects = { OpenButton }

-- 4. TÍNH NĂNG KÉO THẢ (DRAGGABLE) CHO MOBILE
local dragging, dragInput, dragStart, startPos

local function update(input)
    local delta = input.Position - dragStart
    MainFrame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
end

MainFrame.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = true
        dragStart = input.Position
        startPos = MainFrame.Position
        
        input.Changed:Connect(function()
            if input.UserInputState == Enum.UserInputState.End then
                dragging = false
            end
        end)
    end
end)

MainFrame.InputChanged:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
        dragInput = input
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if input == dragInput and dragging then
        update(input)
    end
end)

-- 5. HÀM TẠO THANH TRƯỢT (SLIDER)
local function createSlider(name, text, yOffset, minVal, maxVal, defaultVal, callback)
    local Label = Instance.new("TextLabel")
    Label.Size = UDim2.new(1, -20, 0, 20)
    Label.Position = UDim2.new(0, 10, 0, yOffset)
    Label.Text = text .. ": " .. defaultVal
    Label.TextColor3 = Color3.fromRGB(200, 200, 200)
    Label.TextSize = 14
    Label.BackgroundTransparency = 1
    Label.TextXAlignment = Enum.TextXAlignment.Left
    Label.Parent = MainFrame

    local SliderBar = Instance.new("Frame")
    SliderBar.Size = UDim2.new(1, -20, 0, 10)
    SliderBar.Position = UDim2.new(0, 10, 0, yOffset + 22)
    SliderBar.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
    SliderBar.Parent = MainFrame

    local SliderBtn = Instance.new("TextButton")
    SliderBtn.Size = UDim2.new(0, 20, 0, 20)
    SliderBtn.Position = UDim2.new(0, ((defaultVal - minVal) / (maxVal - minVal)) * 180, 0, -5)
    SliderBtn.BackgroundColor3 = Color3.fromRGB(0, 170, 255)
    SliderBtn.Text = ""
    SliderBtn.Parent = SliderBar
    
    local BtnCorner = Instance.new("UICorner")
    BtnCorner.CornerRadius = UDim.new(1, 0)
    BtnCorner.Parent = SliderBtn

    table.insert(RainbowObjects, SliderBtn)

    local sliding = false

    SliderBtn.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            sliding = true
        end
    end)

    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            sliding = false
        end
    end)

    UserInputService.InputChanged:Connect(function(input)
        if sliding and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            local mousePos = input.Position.X
            local barStart = SliderBar.AbsolutePosition.X
            local barWidth = SliderBar.AbsoluteSize.X
            local percentage = math.clamp((mousePos - barStart) / barWidth, 0, 1)
            
            SliderBtn.Position = UDim2.new(0, percentage * (barWidth - 20), 0, -5)
            
            local calculatedValue = math.floor(minVal + (percentage * (maxVal - minVal)))
            Label.Text = text .. ": " .. calculatedValue
            callback(calculatedValue)
        end
    end)
end

-- 6. HÀM TẠO NÚT BẤM CHỨC NĂNG (BUTTON)
local function createButton(name, text, yOffset, callback)
    local Btn = Instance.new("TextButton")
    Btn.Name = name
    Btn.Size = UDim2.new(1, -20, 0, 30)
    Btn.Position = UDim2.new(0, 10, 0, yOffset)
    Btn.BackgroundColor3 = Color3.fromRGB(0, 170, 255)
    Btn.Text = text
    Btn.TextColor3 = Color3.fromRGB(255, 255, 255)
    Btn.TextSize = 14
    Btn.Font = Enum.Font.SourceSansBold
    Btn.Parent = MainFrame

    local BtnCorner = Instance.new("UICorner")
    BtnCorner.CornerRadius = UDim.new(0, 5)
    BtnCorner.Parent = Btn

    table.insert(RainbowObjects, Btn)

    Btn.MouseButton1Click:Connect(callback)
end

-- 7. LOGIC ĐIỀU KHIỂN NHÂN VẬT & CÁC TÍNH NĂNG GLITCH TẤU HÀI
local currentSpeed = 16
local currentJump = 50

local function updateCharacter(char)
    local humanoid = char:WaitForChild("Humanoid")
    if humanoid then
        humanoid.UseJumpPower = true
        humanoid.WalkSpeed = currentSpeed
        humanoid.JumpPower = currentJump
    end
end

LocalPlayer.CharacterAdded:Connect(updateCharacter)
if LocalPlayer.Character then updateCharacter(LocalPlayer.Character) end

-- TÍNH NĂNG: NHẢY LIÊN TỤC (INFINITE JUMP)
UserInputService.JumpRequest:Connect(function()
    if LocalPlayer.Character and LocalPlayer.Character:FindFirstChildOfClass("Humanoid") then
        LocalPlayer.Character:FindFirstChildOfClass("Humanoid"):ChangeState("Jumping")
    end
end)

-- GLITCH 1: XOAY VÒNG TRÒN SIÊU TỐC TẠI CHỖ (SPIN BOT)
local isSpinning = false
local spinVelocity = nil

local function toggleSpin()
    local character = LocalPlayer.Character
    local hrp = character and character:FindFirstChild("HumanoidRootPart")
    if not hrp then return end

    isSpinning = not isSpinning
    if isSpinning then
        -- Tạo lực xoay BodyAngularVelocity để nhân vật xoay tít thò lò
        spinVelocity = Instance.new("BodyAngularVelocity")
        spinVelocity.Name = "SpinGlitchForce"
        spinVelocity.MaxTorque = Vector3.new(0, math.huge, 0)
        spinVelocity.AngularVelocity = Vector3.new(0, 50, 0) -- Tốc độ xoay tròn
        spinVelocity.Parent = hrp
    else
        if hrp:FindFirstChild("SpinGlitchForce") then
            hrp.SpinGlitchForce:Destroy()
        end
        if spinVelocity then
            spinVelocity:Destroy()
            spinVelocity = nil
        end
    end
end

-- GLITCH 2: NẰM SÀN LỖI NGAY TẠI CHỖ (LOWER CHARACTER GLITCH)
local isLaidDown = false
local function toggleLayDown()
    local character = LocalPlayer.Character
    local humanoid = character and character:FindFirstChildOfClass("Humanoid")
    if not humanoid then return end

    isLaidDown = not isLaidDown
    if isLaidDown then
        -- Chuyển trạng thái Humanoid sang nằm (Physics) để tạo hiệu ứng trượt sàn lag
        humanoid.PlatformStand = true
    else
        humanoid.PlatformStand = false
    end
end

-- 8. KHỔI TẠO CÁC THANH TRƯỢT VÀ NÚT TÍNH NĂNG
createSlider("Speed", "Tốc độ", 40, 16, 200, 16, function(val)
    currentSpeed = val
    if LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Humanoid") then
        LocalPlayer.Character.Humanoid.WalkSpeed = val
    end
end)

createSlider("Jump", "Nhảy cao", 95, 50, 300, 50, function(val)
    currentJump = val
    if LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Humanoid") then
        LocalPlayer.Character.Humanoid.JumpPower = val
    end
end)

-- Nút 1 ở trên: Bật/Tắt xoay tít thò lò tại chỗ giống lỗi game
createButton("SpinGlitchBtn", "Bật/Tắt xoay vòng tròn", 160, function()
    toggleSpin()
end)

-- Nút 2 ở dưới: Bật/Tắt nằm sàn lỗi/trượt lag
createButton("LayDownGlitchBtn", "Bật/Tắt nằm sàn lỗi", 200, function()
    toggleLayDown()
end)

-- 9. VÒNG LẶP ĐỔI MÀU CẦU VỒNG (RAINBOW LOOP)
local hue = 0
RunService.RenderStepped:Connect(function(deltaTime)
    hue = (hue + (deltaTime * 0.1)) % 1
    local rainbowColor = Color3.fromHSV(hue, 1, 1)
    
    for _, object in ipairs(RainbowObjects) do
        if object and object:IsA("GuiObject") then
            object.BackgroundColor3 = rainbowColor
        end
    end
end)

-- Sự kiện ẩn/hiện Menu
MinimizeButton.MouseButton1Click:Connect(function()
    MainFrame.Visible = false
    OpenButton.Visible = true
end)

OpenButton.MouseButton1Click:Connect(function()
    MainFrame.Visible = true
    OpenButton.Visible = false
end)
