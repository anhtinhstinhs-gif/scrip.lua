-- [[ ROBLOX DUPE TOOL LOCALSCRIPT (MOBILE OPTIMIZED) ]]
-- Tự động chạy độc lập trên Mobile/PC Executor, tối ưu giao diện chạm và kéo thả

local Players = game:GetService("Players")
local UserInputService = game:GetService("UserInputService")
local CoreGui = game:GetService("CoreGui")

local player = Players.LocalPlayer
local playerGui = player:WaitForChild("PlayerGui")

-- Xác định vị trí lưu trữ GUI an toàn (Ưu tiên CoreGui, nếu không có quyền thì dùng PlayerGui)
local targetParent = playerGui
local success, isCoreGui = pcall(function() return CoreGui.Name end)
if success and CoreGui then
    targetParent = CoreGui
end

-- Tránh tạo trùng GUI khi execute nhiều lần
local existingGui = targetParent:FindFirstChild("DupeToolGuiMobile")
if existingGui then existingGui:Destroy() end

-- [[ KHỞI TẠO GUI ]]
local ScreenGui = Instance.new("ScreenGui")
ScreenGui.Name = "DupeToolGuiMobile"
ScreenGui.ResetOnSpawn = false
ScreenGui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
ScreenGui.Parent = targetParent

-- Nút LED chính (Tăng kích thước lên 80x80 để dễ bấm trên màn hình cảm ứng điện thoại)
local LedButton = Instance.new("TextButton")
LedButton.Name = "LedButton"
LedButton.Size = UDim2.new(0, 80, 0, 80)
LedButton.Position = UDim2.new(0.1, 0, 0.4, 0)
LedButton.BackgroundColor3 = Color3.fromRGB(0, 170, 255)
LedButton.Text = "DUPE"
LedButton.TextColor3 = Color3.fromRGB(255, 255, 255)
LedButton.Font = Enum.Font.SourceSansBold
LedButton.TextSize = 20
LedButton.AutoButtonColor = false
LedButton.Active = true -- Cần thiết cho Mobile phản hồi touch tốt hơn
LedButton.Parent = ScreenGui

local UICorner = Instance.new("UICorner")
UICorner.CornerRadius = UDim.new(0, 16)
UICorner.Parent = LedButton

-- Nhãn thông báo (Notification Label) - Đưa lên phía trên nút để không bị ngón tay che khuất
local Notification = Instance.new("TextLabel")
Notification.Name = "Notification"
Notification.Size = UDim2.new(0, 160, 0, 35)
Notification.Position = UDim2.new(0.5, -80, 0, -45)
Notification.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
Notification.TextColor3 = Color3.fromRGB(255, 255, 255)
Notification.Font = Enum.Font.SourceSansBold
Notification.TextSize = 14
Notification.BackgroundTransparency = 0.15
Notification.Visible = false
Notification.Parent = LedButton

local NotifCorner = Instance.new("UICorner")
NotifCorner.CornerRadius = UDim.new(0, 8)
NotifCorner.Parent = Notification

-- [[ CHỨC NĂNG THÔNG BÁO ]]
local currentNotifId = 0
local function showNotification(text, color)
    currentNotifId = currentNotifId + 1
    local myId = currentNotifId
    
    Notification.Text = text
    Notification.TextColor3 = color
    Notification.Visible = true
    
    task.delay(2, function()
        if currentNotifId == myId then
            Notification.Visible = false
        end
    end)
end

-- [[ HIỆU ỨNG CHẠM CẢM ỨNG (TOUCH EFFECT) ]]
LedButton.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.Touch or input.UserInputType == Enum.UserInputType.MouseButton1 then
        LedButton.BackgroundColor3 = Color3.fromRGB(0, 120, 200)
    end
end)

LedButton.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.Touch or input.UserInputType == Enum.UserInputType.MouseButton1 then
        LedButton.BackgroundColor3 = Color3.fromRGB(0, 170, 255)
    end
end)

-- [[ HỆ THỐNG KÉO THẢ TỐI ƯU CHO MOBILE ]]
local dragging = false
local dragInput, dragStart, startPos

LedButton.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.Touch or input.UserInputType == Enum.UserInputType.MouseButton1 then
        dragging = true
        dragStart = input.Position
        startPos = LedButton.Position
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if (input.UserInputType == Enum.UserInputType.Touch or input.UserInputType == Enum.UserInputType.MouseMovement) and dragging then
        local delta = input.Position - dragStart
        LedButton.Position = UDim2.new(
            startPos.X.Scale, 
            startPos.X.Offset + delta.X, 
            startPos.Y.Scale, 
            startPos.Y.Offset + delta.Y
        )
    end
end)

UserInputService.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.Touch or input.UserInputType == Enum.UserInputType.MouseButton1 then
        dragging = false
    end
end)

-- [[ CHỨC NĂNG CHÍNH (CLONE TOOL) ]]
local function doDupe()
    local character = player.Character
    if not character then 
        showNotification("Lỗi: Không có nhân vật!", Color3.fromRGB(255, 85, 85))
        return 
    end
    
    -- Tìm Tool đang cầm trên tay nhân vật
    local currentTool = character:FindFirstChildOfClass("Tool")
    
    if not currentTool then
        showNotification("Không có Tool.", Color3.fromRGB(255, 170, 0))
        return
    end
    
    -- Tiến hành nhân bản cục bộ
    local successClone, clonedTool = pcall(function()
        return currentTool:Clone()
    end)
    
    if successClone and clonedTool then
        local backpack = player:FindFirstChild("Backpack")
        if backpack then
            clonedTool.Parent = backpack
            showNotification("Clone thành công.", Color3.fromRGB(85, 255, 85))
        else
            clonedTool:Destroy()
            showNotification("Clone thất bại.", Color3.fromRGB(255, 85, 85))
        end
    else
        showNotification("Clone thất bại.", Color3.fromRGB(255, 85, 85))
    end
end

LedButton.MouseButton1Click:Connect(doDupe)
