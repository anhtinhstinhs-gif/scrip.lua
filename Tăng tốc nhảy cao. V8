-- 7. LOGIC ĐIỀU KHIỂN NHÂN VẬT & CÁC TÍNH NĂNG GLITCH
local currentSpeed = 16
local currentJump = 50

local function updateCharacter(char)
    local humanoid = char:WaitForChild("Humanoid")
    if humanoid then
        humanoid.UseJumpPower = true
        humanoid.WalkSpeed = currentSpeed
        humanoid.JumpPower = currentJump
    end
end

LocalPlayer.CharacterAdded:Connect(updateCharacter)
if LocalPlayer.Character then updateCharacter(LocalPlayer.Character) end

-- TÍNH NĂNG: NHẢY LIÊN TỤC (INFINITE JUMP)
UserInputService.JumpRequest:Connect(function()
    if LocalPlayer.Character and LocalPlayer.Character:FindFirstChildOfClass("Humanoid") then
        LocalPlayer.Character:FindFirstChildOfClass("Humanoid"):ChangeState("Jumping")
    end
end)

-- GLITCH 1: XOAY VÒNG TRÒN SIÊU TỐC TẠI CHỖ (SPIN BOT)
local isSpinning = false
local spinVelocity = nil

local function toggleSpin()
    local character = LocalPlayer.Character
    local hrp = character and character:FindFirstChild("HumanoidRootPart")
    if not hrp then return end

    isSpinning = not isSpinning
    if isSpinning then
        spinVelocity = Instance.new("BodyAngularVelocity")
        spinVelocity.Name = "SpinGlitchForce"
        spinVelocity.MaxTorque = Vector3.new(0, math.huge, 0)
        spinVelocity.AngularVelocity = Vector3.new(0, 50, 0)
        spinVelocity.Parent = hrp
    else
        if hrp:FindFirstChild("SpinGlitchForce") then hrp.SpinGlitchForce:Destroy() end
        if spinVelocity then spinVelocity:Destroy() spinVelocity = nil end
    end
end

-- GLITCH 2: NẰM SÀN LỖI NGAY TẠI CHỖ
local isLaidDown = false
local function toggleLayDown()
    local character = LocalPlayer.Character
    local humanoid = character and character:FindFirstChildOfClass("Humanoid")
    if not humanoid then return end

    isLaidDown = not isLaidDown
    if isLaidDown then
        humanoid.PlatformStand = true
    else
        humanoid.PlatformStand = false
    end
end

-- TÍNH NĂNG MỚI ĐÃ SỬA LỖI: HITBOX ESP HÌNH VUÔNG TRẮNG CỐ ĐỊNH AN TOÀN
local hitboxActive = false
local espConnection = nil

local function createPartBox(part)
    if not part or part:FindFirstChild("HitboxESPMobile") then return end
    
    local box = Instance.new("BoxHandleAdornment")
    box.Name = "HitboxESPMobile"
    box.Size = part.Size + Vector3.new(0.05, 0.05, 0.05) -- Ôm khít bộ phận, không đổi kích thước theo Camera
    box.AlwaysOnTop = true
    box.ZIndex = 5
    box.Color3 = Color3.fromRGB(255, 255, 255)
    box.Transparency = 0.4
    box.Adornee = part
    box.Parent = part
end

local function applyHitboxESP()
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr ~= LocalPlayer and plr.Character then
            -- Chỉ quét các bộ phận cơ thể chính của nhân vật để tránh crash lỗi Mobile
            for _, v in ipairs(plr.Character:GetChildren()) do
                if v:IsA("BasePart") and v.Name ~= "HumanoidRootPart" then
                    createPartBox(v)
                end
            end
        end
    end
end

local function removeHitboxESP()
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr.Character then
            for _, v in ipairs(plr.Character:GetChildren()) do
                if v:IsA("BasePart") then
                    local box = v:FindFirstChild("HitboxESPMobile")
                    if box then box:Destroy() end
                end
            end
        end
    end
end

local function toggleHitboxESP()
    hitboxActive = not hitboxActive
    if hitboxActive then
        -- Sử dụng vòng lặp tối ưu tránh quá tải bộ nhớ gây lỗi game
        espConnection = RunService.Heartbeat:Connect(function()
            if hitboxActive then
                applyHitboxESP()
            else
                if espConnection then
                    espConnection:Disconnect()
                    espConnection = nil
                end
            end
        end)
    else
        if espConnection then
            espConnection:Disconnect()
            espConnection = nil
        end
        removeHitboxESP()
    end
end

