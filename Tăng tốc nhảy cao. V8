-- TÍNH NĂNG MỚI 1: HITBOX KIẾM TO + AUTO ATTACK KHÔNG LỌC CHẾT NHÂN VẬT
-- =========================================================================
local hitboxSwordActive = false
local swordConnection = nil
local originalSizes = {}

local function resetSwordProperties()
    local character = LocalPlayer.Character
    if not character then return end
    
    -- Khôi phục kích thước ban đầu của tất cả vũ khí
    for tool, oldSize in pairs(originalSizes) do
        if tool and tool.Parent and tool:FindFirstChild("Handle") then
            tool.Handle.Size = oldSize
            tool.Handle.CanCollide = true
        end
    end
    originalSizes = {}
end

local function toggleHitboxSword(btn)
    hitboxSwordActive = not hitboxSwordActive
    if hitboxSwordActive then
        btn.Text = "Hitbox Kiếm: ON"
        swordConnection = RunService.Heartbeat:Connect(function()
            local character = LocalPlayer.Character
            if not character then return end
            
            local tool = character:FindFirstChildOfClass("Tool")
            if tool and tool:FindFirstChild("Handle") then
                -- Lưu lại kích thước cũ nếu chưa lưu
                if not originalSizes[tool] then
                    originalSizes[tool] = tool.Handle.Size
                end
                
                -- Phóng to lưỡi kiếm ra kích thước khổng lồ để quét tầm xa
                tool.Handle.Size = Vector3.new(25, 25, 25)
                tool.Handle.CanCollide = false -- Tắt va chạm tuyệt đối để không bị lọc/đẩy văng nhân vật
                
                -- Tự động kích hoạt hành động chém liên tục
                tool:Activate()
            else
                -- Nếu cất kiếm đi thì tạm thời hồi phục kích thước lưu trữ ẩn
                resetSwordProperties()
            end
        end)
    else
        btn.Text = "Hitbox Kiếm: OFF"
        if swordConnection then
            swordConnection:Disconnect()
            swordConnection = nil
        end
        resetSwordProperties()
    end
end

-- Tự động tắt tính năng khi người chơi bị chết (Reset nhân vật) để tránh lỗi game
LocalPlayer.CharacterRemoving:Connect(function()
    if hitboxSwordActive then
        hitboxSwordActive = false
        if swordConnection then
            swordConnection:Disconnect()
            swordConnection = nil
        end
        originalSizes = {}
    end
end)

